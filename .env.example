# =========================
# Afrawood Video Providers
# =========================

# ---------------------------------
# Google Veo / Gemini API
# ---------------------------------
VITE_VEO_API_KEY=
VITE_VEO_BASE_URL=

# Example:
# VITE_VEO_BASE_URL=https://your-veo-proxy-or-backend.example.com

# ---------------------------------
# Runway API
# ---------------------------------
VITE_RUNWAY_API_KEY=
VITE_RUNWAY_BASE_URL=

# Example:
# VITE_RUNWAY_BASE_URL=https://your-runway-proxy-or-backend.example.com

# ---------------------------------
# Optional defaults
# ---------------------------------
VITE_VIDEO_DEFAULT_PROVIDER=auto
VITE_VIDEO_DEFAULT_ASPECT_RATIO=16:9
VITE_VIDEO_DEFAULT_DURATION=5
VITE_VIDEO_DEFAULT_QUALITY=standard